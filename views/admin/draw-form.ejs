<%- include('../partials/head') %><%- include('../partials/navbar') %><main class="container py-5"><div class="card auth-card border-0 shadow-sm p-4 mx-auto"><h1 class="h2">Create draft draw</h1><form method="post" action="/admin/draws"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label class="form-label">Name</label><input class="form-control mb-3" name="name" required><label class="form-label">Draw date</label><input class="form-control mb-3" type="date" name="drawDate" required><label class="form-label">Ticket price</label><input class="form-control mb-3" type="number" step="0.01" min="0.01" name="ticketPrice" required><label class="form-label">Opens at</label><input class="form-control mb-3" type="datetime-local" name="opensAt" required><label class="form-label">Closes at</label><input class="form-control mb-4" type="datetime-local" name="closesAt" required><button class="btn btn-primary">Create draft</button></form></div></main><%- include('../partials/footer') %>
