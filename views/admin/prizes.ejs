<%- include('../partials/head') %><%- include('../partials/navbar') %><main class="container py-5"><%- include('../partials/alerts') %><div class="d-flex justify-content-between"><h1>Prizes</h1><a class="btn btn-primary align-self-start" href="/admin/prizes/new">Add prize</a></div><div class="row g-3 mt-2"><% prizes.forEach(p=>{ %><div class="col-md-6"><div class="card p-3 border-0 shadow-sm"><strong><%= p.display_order %>. <%= p.name %></strong><span><%= p.description %></span><small><%= p.is_active?'Active':'Inactive' %></small><div class="d-flex gap-2 mt-3"><a class="btn btn-sm btn-outline-primary" href="/admin/prizes/<%= p.id %>/edit">Edit</a><% if(p.is_active){ %><form method="post" action="/admin/prizes/<%= p.id %>/deactivate"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-sm btn-outline-danger">Deactivate</button></form><% } %></div></div></div><% }) %></div></main><%- include('../partials/footer') %>
