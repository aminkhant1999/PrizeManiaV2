<%- include('../partials/head') %><%- include('../partials/navbar') %><main class="container py-5"><%- include('../partials/alerts') %><h1>Admin dashboard</h1><div class="row g-3 my-4"><% Object.entries(counts).forEach(([label,value])=>{ %><div class="col-6 col-lg-3"><div class="card border-0 shadow-sm p-4"><small class="text-secondary text-capitalize"><%= label %></small><strong class="display-6"><%= value %></strong></div></div><% }) %></div><div class="d-flex flex-wrap gap-2 mb-5"><a class="btn btn-primary" href="/admin/draws">Manage draws</a><a class="btn btn-outline-primary" href="/admin/prizes">Manage prizes</a><a class="btn btn-outline-primary" href="/admin/users">Users</a><a class="btn btn-outline-primary" href="/admin/tickets">Tickets</a><a class="btn btn-outline-primary" href="/admin/purchases">Purchases</a></div><h2 class="h4">Recent draws</h2><% draws.forEach(d=>{ %><a class="card p-3 mb-2 text-decoration-none" href="/admin/draws/<%= d.id %>"><strong><%= d.name %></strong><span><%= d.status %></span></a><% }) %></main><%- include('../partials/footer') %>
