<%- include('../partials/head') %><%- include('../partials/navbar') %><main class="container py-5"><%- include('../partials/alerts') %><div class="d-flex justify-content-between"><h1>Draws</h1><a class="btn btn-primary align-self-start" href="/admin/draws/new">Create draw</a></div><div class="table-responsive bg-white mt-4"><table class="table"><thead><tr><th>Name</th><th>Date</th><th>Status</th><th>Tickets</th><th>Winners</th><th></th></tr></thead><tbody><% draws.forEach(d=>{ %><tr><td><%= d.name %></td><td><%= new Date(d.draw_date).toLocaleDateString('en-GB') %></td><td><span class="badge text-bg-secondary"><%= d.status %></span></td><td><%= d.ticket_count %></td><td><%= d.winner_count %></td><td><a href="/admin/draws/<%= d.id %>">Manage</a></td></tr><% }) %></tbody></table></div></main><%- include('../partials/footer') %>
