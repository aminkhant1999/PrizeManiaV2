<%- include('../partials/head') %><%- include('../partials/navbar') %><main class="container py-5"><div class="auth-card card border-0 shadow-sm p-4 mx-auto"><h1 class="h2"><%= prize?'Edit':'Add' %> prize</h1><form method="post" action="<%= prize?`/admin/prizes/${prize.id}`:'/admin/prizes' %>"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label class="form-label">Name</label><input class="form-control mb-3" name="name" required maxlength="120" value="<%= prize?.name||'' %>"><label class="form-label">Description</label><input class="form-control mb-3" name="description" required maxlength="255" value="<%= prize?.description||'' %>"><label class="form-label">Image path</label><input class="form-control mb-3" name="imagePath" value="<%= prize?.image_path||'/images/' %>" required><label class="form-label">Display order</label><input class="form-control mb-3" type="number" name="displayOrder" min="1" value="<%= prize?.display_order||1 %>" required><div class="form-check mb-4"><input class="form-check-input" type="checkbox" id="active" name="isActive" <%= !prize||prize.is_active?'checked':'' %>><label class="form-check-label" for="active">Active</label></div><button class="btn btn-primary"><%= prize?'Save changes':'Create prize' %></button></form></div></main><%- include('../partials/footer') %>
