<%- include('../partials/head') %><%- include('../partials/navbar') %><main class="container py-5"><%- include('../partials/alerts') %><h1><%= draw.name %></h1><p><span class="badge text-bg-secondary"><%= draw.status %></span> · £<%= Number(draw.ticket_price).toFixed(2) %> per ticket</p><div class="card border-0 shadow-sm p-4 my-4"><h2 class="h5">Draw workflow</h2><% if(draw.status==='draft'){ %><form method="post" action="/admin/draws/<%= draw.id %>/status"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="status" value="open"><button class="btn btn-success">Open draw</button></form><% }else if(draw.status==='open'){ %><form method="post" action="/admin/draws/<%= draw.id %>/status"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="status" value="closed"><button class="btn btn-warning">Close draw</button></form><% }else if(draw.status==='closed'){ %><div class="alert alert-warning"><strong>Irreversible action:</strong> winners are selected with cryptographic randomness and cannot be regenerated.</div><div class="d-flex flex-wrap gap-2"><form method="post" action="/admin/draws/<%= draw.id %>/status"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="status" value="open"><button class="btn btn-success">Reopen draw</button></form><form method="post" action="/admin/draws/<%= draw.id %>/select-winners"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-danger">Confirm and select winners</button></form></div><p class="form-text mt-3 mb-0">Reopening enables ticket purchases again until the configured closing time.</p><% }else if(draw.status==='completed'){ %><form method="post" action="/admin/draws/<%= draw.id %>/status"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="status" value="published"><button class="btn btn-primary">Publish results</button></form><% }else{ %><p class="text-success mb-0">Results are public.</p><% } %></div><h2 class="h4">Winners</h2><% if(!winners.length){ %><p>No winners selected.</p><% }else{ %><div class="table-responsive"><table class="table bg-white"><thead><tr><th>Prize</th><th>Winner</th><th>Email</th><th>Ticket</th></tr></thead><tbody><% winners.forEach(w=>{ %><tr><td><%= w.prize_name %></td><td><%= w.user_name %></td><td><%= w.email %></td><td><%= w.ticket_number %></td></tr><% }) %></tbody></table></div><% } %></main><%- include('../partials/footer') %>
