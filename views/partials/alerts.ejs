<% if(errors?.length){ %><div class="alert alert-danger" role="alert"><ul class="mb-0"><% errors.forEach(error=>{ %><li><%= error %></li><% }) %></ul></div><% } %><% messages.forEach(item=>{ %><div class="alert alert-<%= item.type==='error'?'danger':item.type %> alert-dismissible fade show" role="alert"><%= item.message %><button class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div><% }) %>
