<%- include('partials/head') %><%- include('partials/navbar') %><main><section class="hero-section py-5"><div class="container py-lg-4"><div class="row align-items-center g-4"><div class="col-lg-7"><span class="badge text-bg-warning mb-3">Monthly lucky draw</span><h1 class="display-4 fw-bold">Your chance to win something amazing</h1><p class="lead text-secondary">Create an account, use simulated wallet funds, and collect tickets for a fair monthly draw.</p><div class="d-flex gap-3 flex-wrap"><a class="btn btn-primary btn-lg" href="<%= currentUser?'/tickets/buy':'/register' %>"><%= currentUser?'Buy tickets':'Create an account' %></a><a class="btn btn-outline-primary btn-lg" href="#winners">View results</a></div></div><div class="col-lg-5"><div class="hero-card bg-white rounded-4 shadow-sm p-4"><p class="text-primary fw-semibold mb-2">Current draw</p><% if(currentDraw){ %><h2 class="h3"><%= currentDraw.name %></h2><p><strong>£<%= Number(currentDraw.ticket_price).toFixed(2) %></strong> per ticket</p><p class="text-secondary mb-0">Closes <%= new Date(currentDraw.closes_at).toLocaleString('en-GB') %></p><% }else{ %><h2 class="h4">Next draw coming soon</h2><p class="text-secondary mb-0">Please check back when an administrator opens the next draw.</p><% } %></div></div></div></div></section><section class="py-5"><div class="container"><h2 class="fw-bold">Featured prizes</h2><p class="text-secondary mb-4">Active rewards, managed from the database.</p><div class="row g-4"><% prizes.forEach(prize=>{ %><div class="col-sm-6 col-lg-3"><article class="card prize-card h-100 border-0 shadow-sm"><div class="prize-image-wrapper"><img src="<%= prize.image_path %>" class="prize-image" alt="<%= prize.name %>"></div><div class="card-body"><p class="text-primary small fw-semibold"><%= prize.description %></p><h3 class="h5"><%= prize.name %></h3></div></article></div><% }) %></div></div></section><section id="winners" class="winners-section py-5"><div class="container"><h2 class="fw-bold">Published winners</h2><p class="text-secondary">Only administrator-approved results appear here.</p><% if(!winners.length){ %><div class="empty-state bg-white rounded-4 p-5 text-center">No results have been published yet.</div><% }else{ %><div class="table-responsive bg-white rounded-4"><table class="table align-middle mb-0"><thead><tr><th>Winner</th><th>Month</th><th>Prize</th><th>Ticket</th></tr></thead><tbody><% winners.forEach(w=>{ %><tr><td><%= w.winnerName %></td><td><%= w.monthLabel %></td><td><%= w.prize %></td><td><%= w.ticketId %></td></tr><% }) %></tbody></table></div><% } %></div></section></main><%- include('partials/footer') %>
