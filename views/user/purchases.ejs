<%- include('../partials/head') %><%- include('../partials/navbar') %><main class="container py-5"><h1>Purchase history</h1><p class="text-secondary">Simulated transactions only.</p><div class="table-responsive bg-white"><table class="table"><thead><tr><th>Draw</th><th>Quantity</th><th>Unit price</th><th>Total</th><th>Date</th></tr></thead><tbody><% purchases.forEach(p=>{ %><tr><td><%= p.draw_name %></td><td><%= p.quantity %></td><td>£<%= Number(p.unit_price).toFixed(2) %></td><td>£<%= Number(p.total_amount).toFixed(2) %></td><td><%= new Date(p.created_at).toLocaleString('en-GB') %></td></tr><% }) %></tbody></table></div></main><%- include('../partials/footer') %>
