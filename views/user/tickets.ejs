<%- include('../partials/head') %><%- include('../partials/navbar') %><main class="container py-5"><%- include('../partials/alerts') %><div class="d-flex justify-content-between mb-4"><div><h1>My tickets</h1><p class="text-secondary">Every ticket is stored individually.</p></div><a class="btn btn-primary align-self-start" href="/tickets/buy">Buy tickets</a></div><% if(!tickets.length){ %><div class="empty-state bg-white p-5 text-center rounded-4">You do not own any tickets yet.</div><% }else{ %><div class="row g-3"><% tickets.forEach(t=>{ %><div class="col-md-6 col-lg-4"><div class="ticket-card card border-0 shadow-sm p-4"><small class="text-secondary"><%= t.draw_name %></small><strong class="font-monospace fs-5"><%= t.ticket_number %></strong><span class="badge text-bg-secondary align-self-start mt-3"><%= t.draw_status %></span></div></div><% }) %></div><% } %></main><%- include('../partials/footer') %>
