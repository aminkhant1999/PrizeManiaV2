<%- include('../partials/head') %><%- include('../partials/navbar') %><main class="container py-5"><%- include('../partials/alerts') %><div class="d-flex justify-content-between align-items-center mb-4"><div><h1>Welcome, <%= user.name %></h1><p class="text-secondary mb-0">Your PrizeMania account at a glance.</p></div><div class="balance-card rounded-4 p-3"><small>Simulated balance</small><strong class="d-block fs-3">£<%= Number(user.wallet_balance).toFixed(2) %></strong></div></div><div class="row g-4 mb-5"><div class="col-md-4"><div class="card h-100 p-4 border-0 shadow-sm"><h2 class="h5">Current draw</h2><p><%= draw?draw.name:'No open draw' %></p><a class="btn btn-primary <%= draw?'':'disabled' %>" href="/tickets/buy">Buy tickets</a></div></div><div class="col-md-4"><div class="card h-100 p-4 border-0 shadow-sm"><h2 class="h5">My tickets</h2><p class="display-6"><%= tickets.length %><%= tickets.length===5?'+':'' %></p><a href="/tickets">View all</a></div></div><div class="col-md-4"><div class="card h-100 p-4 border-0 shadow-sm"><h2 class="h5">Published prizes won</h2><p class="display-6"><%= wins.length %></p></div></div></div><h2 class="h4">Recent purchases</h2><% if(!purchases.length){ %><p class="empty-state bg-white p-4 rounded-3">You have not purchased tickets yet.</p><% }else{ %><div class="table-responsive"><table class="table bg-white"><thead><tr><th>Draw</th><th>Quantity</th><th>Total</th><th>Date</th></tr></thead><tbody><% purchases.forEach(p=>{ %><tr><td><%= p.draw_name %></td><td><%= p.quantity %></td><td>£<%= Number(p.total_amount).toFixed(2) %></td><td><%= new Date(p.created_at).toLocaleString('en-GB') %></td></tr><% }) %></tbody></table></div><% } %></main><%- include('../partials/footer') %>
