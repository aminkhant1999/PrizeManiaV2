<%- include('../partials/head') %><%- include('../partials/navbar') %><main class="container py-5"><div class="auth-card card border-0 shadow-sm p-4 mx-auto"><h1 class="h2">Buy tickets</h1><%- include('../partials/alerts') %><% if(!draw){ %><p>No draw is currently accepting purchases.</p><a href="/dashboard">Return to dashboard</a><% }else{ %><h2 class="h5"><%= draw.name %></h2><p>£<%= Number(draw.ticket_price).toFixed(2) %> per ticket. Closes <%= new Date(draw.closes_at).toLocaleString('en-GB') %>.</p><form method="post" action="/tickets/buy"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="drawId" value="<%= draw.id %>"><label class="form-label" for="quantity">Quantity</label><input class="form-control mb-3" id="quantity" name="quantity" type="number" min="1" max="<%= maxQuantity %>" value="1" required><button class="btn btn-primary w-100">Confirm simulated purchase</button></form><p class="form-text mt-3">The total is calculated securely on the server.</p><% } %></div></main><%- include('../partials/footer') %>
