<%- include('../partials/head') %><%- include('../partials/navbar') %><main class="container py-5"><div class="auth-card card border-0 shadow-sm p-4 mx-auto"><h1 class="h2"><%= admin?'Administrator':'User' %> sign in</h1><p class="text-secondary"><%= admin?'Protected management access.':'View your tickets, purchases and prizes.' %></p><%- include('../partials/alerts') %><form method="post" action="<%= admin?'/admin/login':'/login' %>"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="mb-3"><label class="form-label" for="email">Email</label><input class="form-control" type="email" id="email" name="email" required value="<%= old.email||'' %>" autocomplete="username"></div><div class="mb-4"><label class="form-label" for="password">Password</label><input class="form-control" type="password" id="password" name="password" required autocomplete="current-password"></div><button class="btn btn-primary w-100">Sign in</button></form><hr><a href="<%= admin?'/login':'/admin/login' %>"><%= admin?'User sign in':'Administrator sign in' %></a></div></main><%- include('../partials/footer') %>
